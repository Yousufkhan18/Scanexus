<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
        body {
            background: #03030a;
            color: #cbd5e1;
            padding-top: 90px;
        }

        .student-navbar {
            background: rgba(11, 11, 30, 0.75) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .custom-navbar-toggler {
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.02);
            padding: 6px 12px;
            border-radius: 8px;
            color: #fff;
        }

            .custom-navbar-toggler:focus {
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.25);
                border-color: #3b82f6;
            }

        .btn-logout-custom {
            background: rgba(239, 68, 68, 0.05);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 6px 16px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .btn-logout-custom:hover {
                background: rgba(239, 68, 68, 0.15);
                border-color: #ef4444;
                color: #fca5a5;
            }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top student-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3 text-decoration-none" href="/Student/Dashboard">
                <!-- Modernized Hexagon Logo Icon Box -->
                <div style="position: relative; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <div style="position: absolute; inset: 0; background: linear-gradient(135deg, #2563eb, #4f46e5); clip-path: polygon(50% 0%, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%); box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);"></div>
                    <i class="bi bi-qr-code-scan" style="position: relative; z-index: 1; font-size: 1.2rem; color: #ffffff; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);"></i>
                </div>

                <!-- Branding Text Hierarchy -->
                <div class="d-flex flex-column">
                    <div style="font-size: 1.25rem; font-weight: 800; color: #ffffff; line-height: 1.1; letter-spacing: -0.3px;">
                        Scan<span style="background: linear-gradient(135deg, #60a5fa, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">exus</span>
                    </div>
                    <div style="font-size: 0.72rem; font-weight: 600; color: #94a3b8; letter-spacing: 1.5px; text-transform: uppercase; margin-top: 2px; opacity: 0.9;">
                        Scan &bull; Borrow &bull; Read
                    </div>
                </div>
            </a>
            <button class="navbar-toggler custom-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#studentNavbarContent">
                <i class="bi bi-list" style="font-size: 1.3rem;"></i>
            </button>

            <div class="collapse navbar-collapse" id="studentNavbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 mt-2 mt-lg-0">
                </ul>
                <!-- Right Side Framework Controls Structure -->
                <div class="ms-auto d-flex align-items-center gap-3 mt-2 mt-lg-0">
                    <span class="text-white-50 small"><i class="bi bi-person me-1"></i> Student Portal</span>
                    <!-- Seamless Logout Anchor Interface Link -->
                    <a href="/Student/Logout" class="btn-logout-custom">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container main-wrapper">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>