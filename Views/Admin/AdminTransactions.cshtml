@using System.Text.Encodings.Web
@model List<LibrarySystem.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .page-header {
            margin-bottom: 2rem;
        }

            .page-header h4 {
                color: #fff;
                font-weight: 800;
                margin: 0;
                font-size: 1.4rem;
                letter-spacing: -0.3px;
            }

            .page-header p {
                color: #64748b;
                font-size: 0.88rem;
                margin: 4px 0 0;
                font-weight: 500;
            }

        /* Premium System Matrix Card Container */
        .data-table-container {
            background: rgba(11, 11, 30, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            width: 100%; /* Force fill */
            margin-top: 1rem;
        }

        .table {
            margin: 0;
            color: #cbd5e1;
        }

            .table thead th {
                background: rgba(5, 5, 15, 0.8);
                color: #94a3b8;
                font-size: 0.72rem;
                letter-spacing: 1px;
                text-transform: uppercase;
                border-color: rgba(255, 255, 255, 0.05);
                padding: 1rem 1.4rem;
                font-weight: 600;
            }

            .table tbody td {
                border-color: rgba(255, 255, 255, 0.03);
                padding: 1.1rem 1.4rem;
                vertical-align: middle;
                font-size: 0.92rem;
                background: transparent;
            }

            .table tbody tr:hover td {
                background: rgba(255, 255, 255, 0.02);
                color: #fff;
            }

        .txn-code-spec {
            color: #60a5fa;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.82rem;
            font-weight: 500;
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.15);
            padding: 6px 12px;
            border-radius: 8px;
            white-space: nowrap; /* Prevents text wrapping into two lines */
            display: inline-block;
        }

        .student-name-cell {
            color: #f1f5f9;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .student-id-cell {
            color: #64748b;
            font-size: 0.78rem;
            margin-top: 3px;
            font-weight: 500;
        }

        .book-title-cell {
            color: #cbd5e1;
            font-weight: 500;
        }

        .date-text-cell {
            color: #94a3b8;
            font-size: 0.88rem;
            white-space: nowrap; /* Ensures dates stay crisp on one line too */
        }

        .fine-glowing-text {
            color: #fca5a5;
            font-weight: 700;
            font-size: 0.92rem;
            text-shadow: 0 0 10px rgba(239, 68, 68, 0.15);
        }

        /* Badges */
        .badge-status-active {
            background: rgba(34, 197, 94, 0.1);
            color: #86efac;
            border: 1px solid rgba(34, 197, 94, 0.2);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-status-returned {
            background: rgba(148, 163, 184, 0.08);
            color: #94a3b8;
            border: 1px solid rgba(148, 163, 184, 0.15);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-status-overdue {
            background: rgba(239, 68, 68, 0.1);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .btn-action-edit {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: #94a3b8;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 10px;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .btn-action-edit:hover {
                background: rgba(255, 255, 255, 0.06);
                border-color: rgba(255, 255, 255, 0.15);
                color: #fff;
            }

        /* Global Shared Modal Framework Fixes */
        .premium-modal-box {
            background: #0b0b1e !important;
            border: 1px solid rgba(255, 255, 255, 0.12) !important;
            border-radius: 16px !important;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.7) !important;
        }

        .premium-modal-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.06) !important;
            padding: 1.2rem 1.5rem;
        }

        .premium-modal-footer {
            border-top: 1px solid rgba(255, 255, 255, 0.06) !important;
            padding: 1rem 1.5rem;
        }

        .modal-form-label {
            color: #64748b;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            display: block;
        }

        /* Solid State High Visibility Date Field Selector */
        .modal-custom-control {
            background: #04040d !important;
            border: 1px solid rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
            border-radius: 10px !important;
            height: 48px !important;
            padding: 0.5rem 1rem !important;
            font-size: 0.95rem !important;
            width: 100% !important;
            display: block !important;
        }

            .modal-custom-control::-webkit-calendar-picker-indicator {
                filter: invert(1) brightness(100%);
                cursor: pointer;
            }

        .btn-modal-save {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: #fff !important;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            padding: 0.55rem 1.4rem;
        }
    </style>
}

<div class="page-header">
    <h4><i class="bi bi-clock-history me-2" style="color:#3b82f6;"></i>All Transactions Log</h4>
    <p>Complete execution history stream — @Model.Count operations indexed</p>
</div>

<div class="data-table-container">
    <div class="table-responsive">
        <table class="table align-middle w-100" style="table-layout: auto;">
            <thead>
                <tr>
                    <th style="width: 18%;">Transaction ID</th>
                    <th style="width: 16%;">Borrower Profile</th>
                    <th style="width: 18%;">Book Title</th>
                    <th style="width: 11%;">Issue Date</th>
                    <th style="width: 11%;">Due Deadline</th>
                    <th style="width: 11%;">Return Date</th>
                    <th style="width: 10%;">Fine Accrued</th>
                    <th style="width: 5%;">Status</th>
                    <th style="width: 10%; text-align: center;">Operational Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td><span class="txn-code-spec">@t.TxnCode</span></td>

                        <td>
                            <div class="student-name-cell">@t.Student?.FullName</div>
                            <div class="student-id-cell">@t.Student?.UniversityID</div>
                        </td>

                        <td><span class="book-title-cell">@t.Book?.Title</span></td>

                        <td><span class="date-text-cell">@t.IssueDate.ToString("dd MMM yyyy")</span></td>

                        <td>
                            @if (t.DueDate < DateTime.Now && t.Status == "Active")
                            {
                                <span style="color: #fca5a5; font-weight: 600; white-space: nowrap;">@t.DueDate.ToString("dd MMM yyyy")</span>
                            }
                            else
                            {
                                <span class="date-text-cell">@t.DueDate.ToString("dd MMM yyyy")</span>
                            }
                        </td>

                        <td>
                            <span class="date-text-cell">@(t.ReturnDate.HasValue? t.ReturnDate.Value.ToString("dd MMM yyyy") : "—")</span>
                        </td>

                        <td>
                            @if (t.FineAmount > 0)
                            {
                                <span class="fine-glowing-text" style="white-space: nowrap;">Rs. @t.FineAmount</span>
                            }
                            else
                            {
                                <span style="color: #475569; font-weight: 500;">—</span>
                            }
                        </td>

                        <td>
                            @if (t.Status == "Active")
                            {
                                <span class="badge-status-active">Active</span>
                            }
                            else if (t.Status == "Returned")
                            {
                                <span class="badge-status-returned">Returned</span>
                            }
                            else
                            {
                                <span class="badge-status-overdue">Overdue</span>
                            }
                        </td>

                        <td style="text-align: center;">
                            @if (t.Status != "Returned")
                            {
                                <button type="button" class="btn-action-edit"
                                        onclick="openEditDueModal('@t.TransactionID', '@t.TxnCode', '@JavaScriptEncoder.Default.Encode(t.Book?.Title ?? "")', '@t.DueDate.ToString("yyyy-MM-dd")')">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </button>
                            }
                            else
                            {
                                <span style="color: #475569;"><i class="bi bi-lock-fill"></i></span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="globalEditDueModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal-box">
            <div class="premium-modal-header modal-header">
                <h5 class="text-white fw-bold mb-0 d-flex align-items-center gap-2" style="font-size:1.1rem;">
                    <i class="bi bi-calendar-event text-primary"></i> Modulate Due Date
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateDueDate" asp-controller="Admin" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <input type="hidden" id="modalTransactionId" name="transactionId" />

                <div class="modal-body p-4">
                    <div class="mb-4">
                        <span class="modal-form-label">Active Operation Entity</span>
                        <div class="p-3" style="background: rgba(5,5,15,0.6); border-radius: 10px; border: 1px solid rgba(255,255,255,0.05);">
                            <span class="txn-code-spec" id="modalTxnCode" style="font-size:0.78rem;"></span>
                            <div class="text-white fw-semibold small mt-2" id="modalBookTitle"></div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="modal-form-label">Adjust New Target Deadline</label>
                        <input type="date" id="modalNewDueDate" name="newDueDate" class="form-control modal-custom-control" required />
                    </div>
                </div>

                <div class="modal-footer premium-modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary px-3" style="border-radius:10px; font-weight:600;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-modal-save btn-sm"> Update </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Smooth global parser handling logic
        function openEditDueModal(id, code, title, dueDate) {
            document.getElementById('modalTransactionId').value = id;
            document.getElementById('modalTxnCode').innerText = code;
            document.getElementById('modalBookTitle').innerText = title;
            document.getElementById('modalNewDueDate').value = dueDate;

            // Fires up the clean un-clipped modal instance
            var targetModal = new bootstrap.Modal(document.getElementById('globalEditDueModal'));
            targetModal.show();
        }
    </script>
}