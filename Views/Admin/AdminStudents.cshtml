@model List<LibrarySystem.Models.Student>
@{
    ViewData["Title"] = "Students";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

            .page-header h4 {
                color: #fff;
                font-weight: 800;
                margin: 0;
                font-size: 1.4rem;
                letter-spacing: -0.3px;
            }

            .page-header p {
                color: #64748b;
                font-size: 0.88rem;
                margin: 4px 0 0;
                font-weight: 500;
            }

        .btn-add {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.25);
            border: none;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            padding: 0.65rem 1.4rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            white-space: nowrap;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .btn-add:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35);
                color: #fff;
                opacity: 0.95;
            }

        .section-card {
            background: rgba(11, 11, 30, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            overflow: hidden;
        }

        .table {
            margin: 0;
            color: #cbd5e1;
        }

            .table thead th {
                background: rgba(5, 5, 15, 0.8);
                color: #94a3b8;
                font-size: 0.72rem;
                letter-spacing: 1px;
                text-transform: uppercase;
                border-color: rgba(255, 255, 255, 0.05);
                padding: 1rem 1.4rem;
                font-weight: 600;
            }

            .table tbody td {
                border-color: rgba(255, 255, 255, 0.03);
                padding: 1rem 1.4rem;
                vertical-align: middle;
                font-size: 0.92rem;
                background: transparent;
            }

            .table tbody tr:hover td {
                background: rgba(255, 255, 255, 0.02);
                color: #fff;
            }

        .avatar {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: rgba(37, 99, 235, 0.1);
            border: 1px solid rgba(59, 130, 246, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #60a5fa;
            dominant-baseline: middle;
            font-weight: 700;
            font-size: 0.95rem;
            flex-shrink: 0;
        }

        .student-name {
            color: #f1f5f9;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .student-father {
            color: #64748b;
            font-size: 0.78rem;
            margin-top: 3px;
            font-weight: 500;
        }

        .uid-code {
            color: #60a5fa;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.85rem;
            font-weight: 500;
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.15);
            padding: 4px 10px;
            border-radius: 8px;
        }

        .text-muted-custom {
            color: #94a3b8;
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Vibrant High-Contrast Neon Badges */
        .badge-active {
            background: rgba(34, 197, 94, 0.1);
            color: #86efac;
            border: 1px solid rgba(34, 197, 94, 0.2);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-inactive {
            background: rgba(239, 68, 68, 0.1);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        /* Action Buttons Interaction Controls */
        .btn-deactivate {
            background: rgba(239, 68, 68, 0.05);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 10px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }

            .btn-deactivate:hover {
                background: rgba(239, 68, 68, 0.15);
                border-color: #ef4444;
                color: #fca5a5;
            }

        .btn-activate {
            background: rgba(34, 197, 94, 0.05);
            border: 1px solid rgba(34, 197, 94, 0.2);
            color: #86efac;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 10px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }

            .btn-activate:hover {
                background: rgba(34, 197, 94, 0.15);
                border-color: #22c55e;
                color: #86efac;
            }

        /* Beautiful Clean Empty States Grid */
        .empty-state {
            text-align: center;
            padding: 4rem 1.5rem;
            color: #475569;
        }

            .empty-state i {
                font-size: 3rem;
                display: block;
                margin-bottom: 0.8rem;
                color: #334155;
            }
    </style>
}

<div class="page-header">
    <div>
        <h4><i class="bi bi-people-fill me-2" style="color:#3b82f6;"></i>Student Database</h4>
        <p>Manage registry profiles and system permissions</p>
    </div>
    <a href="/Admin/AddStudent" class="btn-add">
        <i class="bi bi-person-plus-fill"></i> Register Student
    </a>
</div>

<div class="section-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-people-fill"></i>
            No students registered in the database yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Student Matrix Details</th>
                        <th>University ID</th>
                        <th>Email Endpoint</th>
                        <th>Semester</th>
                        <th>Cohort Batch</th>
                        <th>Access Status</th>
                        <th>Operational Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar">@(string.IsNullOrEmpty(s.FullName) ? "S" : s.FullName[0].ToString().ToUpper())</div>
                                    <div>
                                        <div class="student-name">@s.FullName</div>
                                        <div class="student-father">@s.FatherName</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="uid-code">@s.UniversityID</span></td>
                            <td><span class="text-muted-custom">@s.Email</span></td>
                            <td><span class="text-muted-custom">@s.Semester</span></td>
                            <td><span class="text-muted-custom">@s.Batch</span></td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <span class="badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">Inactive</span>
                                }
                            </td>
                            <td>
                                <form asp-action="ToggleStudent" method="post" style="display:inline; margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.StudentID" />
                                    <button class="@(s.IsActive ? "btn-deactivate" : "btn-activate")" type="submit">
                                        @(s.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>